# ===========================================
# RAG 知识库环境变量模板
# ===========================================
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 填入真实值
#   3. 切换到本地 Ollama 时，只需改 LLM_BASE_URL 和 LLM_MODEL
#
# ⚠️ .env 文件已加入 .gitignore，请勿提交
# ===========================================

# ===== LLM / VLM（云端百炼，OpenAI 兼容协议）=====
LLM_PROVIDER=bailian
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-omni-flash
LLM_API_KEY=sk-请填入你的百炼API_Key

# ===== Rerank（云端百炼，私有协议）=====
RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1
RERANK_MODEL=gte-rerank-v2

# ===== Embedding（本地 bge-m3 通过 infinity 服务）=====
EMBED_BASE_URL=http://localhost:8080
EMBED_MODEL=BAAI/bge-m3

# ===== 数据库 =====
POSTGRES_URL=postgresql+asyncpg://rag:ragpass@localhost:5432/rag
POSTGRES_URL_SYNC=postgresql+psycopg2://rag:ragpass@localhost:5432/rag
QDRANT_URL=http://localhost:6333

# ===== 对象存储（RustFS，S3 兼容）=====
STORAGE_BACKEND=rustfs
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=rustfsadmin
STORAGE_SECRET_KEY=rustfsadmin-please-change-me
STORAGE_BUCKET=rag-documents
STORAGE_REGION=us-east-1
# STORAGE_PUBLIC_ENDPOINT=https://files.example.com

# ===== RustFS 宿主端口映射（仅 Windows Hyper-V 端口冲突时启用）=====
# Windows 11 默认保留 8999-9098 段给 Hyper-V/WSL2，会导致 docker compose up rustfs 报
# "bind: forbidden by its access permissions"。检查方法：
#   netsh interface ipv4 show excludedportrange protocol=tcp
# 命中保留段时，取消注释下两行并把 STORAGE_ENDPOINT 同步改成 http://localhost:9100：
# STORAGE_API_PORT=9100
# STORAGE_CONSOLE_PORT=9101

# ===== 应用 =====
APP_ENV=dev
ALLOW_LOCAL_IDP_IN_PROD=false
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ===== 身份认证（IdP）=====
IDP_PROVIDER=local
LOCAL_USERS=[]

# ===== 切换到本地 Ollama 示例（注释掉的）=====
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:3b
# LLM_API_KEY=ollama-no-key-needed
